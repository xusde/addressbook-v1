pipeline {
    agent none

    parameters {
        string(name: 'Env', defaultValue: 'Test', description: 'Version to deploy')
        booleanParam(name: 'executeTests', defaultValue: true, description: 'Decide to run test cases')
        choice(name: 'APPVERSION', choices: ['1.1', '1.2', '1.3'], description: 'Select application version')
    }

    environment {
        BUILD_SERVER='ubuntu@172.31.0.136'
     }


    stages {
        stage('Compile') {
            agent any
            steps {
                script {
                     sshagent(['ssh-agent-plugin']) {
                         echo "Compiling the code ${params.Env}"
                         sh "scp -o StrictHostKeyChecking=no server-script1.sh ${BUILD_SERVER}:/home/ubuntu"
                         sh "ssh -o StrictHostKeyChecking=no ${BUILD_SERVER} 'bash /home/ubuntu/server-script1.sh'"
                    }
                }    
            }
        }
        stage("Code Analysis") {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Code Analysis'
                    sh 'mvn pmd:pmd'
                }
            }
        }
        stage('Unit Test') {
            agent any
            when {
                expression { params.executeTests == true }
            }
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Unit Test'
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }
        
        stage('Code Coverage') {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo "Code Coverages ${params.APPVERSION}"
                    sh 'mvn verify'
                }
            }
        }
        
        stage('Packaging') {
            agent { label 'slave5-labels' }
            tools {  maven 'mymaven' }

            input{
               message "Package the code"
               ok "Platform selected"
               parameters{
                   choice(name:'Platform',choices:['Ec2','OnPrem'])
               }
           }

            steps {
                script {
                      echo 'Packaging'
                      sh 'mvn package'
                }
            }
        }
    }
}
