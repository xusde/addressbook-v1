pipeline {
    agent none

    parameters {
        string(name: 'Env', defaultValue: 'Test', description: 'Version to deploy')
        booleanParam(name: 'executeTests', defaultValue: true, description: 'Decide to run test cases')
        choice(name: 'APPVERSION', choices: ['1.1', '1.2', '1.3'], description: 'Select application version')
    }

    stages {
        stage('Compile') {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo "Compile ${params.Env}"
                    sh 'mvn compile'
                }
            }
        }
        stage("Code Analysis") {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Code Analysis'
                    sh 'mvn pmd:pmd'
                }
            }
        }
        stage('Unit Test') {
            agent any
            when {
                expression { params.executeTests == true }
            }
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Unit Test'
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }
        
        stage('Code Coverage') {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo "Code Coverages ${params.APPVERSION}"
                    sh 'mvn verify'
                }
            }
        }
        
        stage('Packaging') {
            agent { label 'slave5-labels' }
            tools {  maven 'mymaven' }
            steps {
                script {
                      echo 'Packaging'
                      sh 'mvn package'
                }
            }
        }
    }
}
