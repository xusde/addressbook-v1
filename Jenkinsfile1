pipeline {
    agent none
    stages {
        stage('Compile') {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Compile'
                    sh 'mvn compile'
                }
            }
        }
        stage("Code Analysis") {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Code Analysis'
                    sh 'mvn pmd:pmd'
                }
            }
        }
        stage('Unit Test') {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Unit Test'
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }
        
        stage('Code Coverage') {
            agent any
            tools {  maven 'mymaven' }
            steps {
                script {
                    echo 'Code Coverages'
                    sh 'mvn verify'
                }
            }
        }
        
        stage('Packaging') {
            agent { label 'slave5-labels' }
            tools {  maven 'mymaven' }
            steps {
                script {
                      echo 'Packaging'
                      sh 'mvn package'
                }
            }
        }
    }
}
